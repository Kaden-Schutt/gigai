{
  "serverName": "my-machine",
  "server": {
    "port": 7443,
    "host": "0.0.0.0",
    "https": {
      "provider": "tailscale",
      "funnelPort": 7443
    }
  },
  "auth": {
    "encryptionKey": "your-64-char-hex-key-here-generate-with-openssl-rand-hex-32-cmd",
    "pairingTtlSeconds": 300,
    "sessionTtlSeconds": 14400
  },
  "tools": [
    {
      "type": "builtin",
      "name": "read",
      "builtin": "read",
      "description": "Read file contents",
      "config": {
        "allowedPaths": ["/home/user/projects"]
      }
    },
    {
      "type": "builtin",
      "name": "write",
      "builtin": "write",
      "description": "Write content to files",
      "config": {
        "allowedPaths": ["/home/user/projects"]
      }
    },
    {
      "type": "builtin",
      "name": "edit",
      "builtin": "edit",
      "description": "Edit files by replacing text",
      "config": {
        "allowedPaths": ["/home/user/projects"]
      }
    },
    {
      "type": "builtin",
      "name": "glob",
      "builtin": "glob",
      "description": "Find files matching glob patterns",
      "config": {
        "allowedPaths": ["/home/user/projects"]
      }
    },
    {
      "type": "builtin",
      "name": "grep",
      "builtin": "grep",
      "description": "Search file contents",
      "config": {
        "allowedPaths": ["/home/user/projects"]
      }
    },
    {
      "type": "builtin",
      "name": "bash",
      "builtin": "bash",
      "description": "Execute bash commands",
      "config": {
        "allowlist": ["ls", "cat", "head", "tail", "grep", "find", "wc", "git", "npm", "node"],
        "allowSudo": false
      }
    },
    {
      "type": "mcp",
      "name": "browser",
      "command": "npx",
      "args": ["-y", "@anthropic-ai/mcp-server-puppeteer"],
      "description": "Browser automation via Puppeteer"
    },
    {
      "type": "cli",
      "name": "docker",
      "command": "docker",
      "description": "Docker container management",
      "timeout": 60000
    }
  ]
}
